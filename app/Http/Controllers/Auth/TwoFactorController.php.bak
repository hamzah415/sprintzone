<?php

namespace App\Http\Controllers\Auth;

use App\Http\Controllers\Controller;
use Illuminate\Http\Request;
use PragmaRX\Google2FALaravel\Support\Authenticator;

class TwoFactorController extends Controller
{
	public function showSetupForm(Request $request)
	{
		$google2fa = app('pragmarx.google2fa');
    		$user = auth()->user();

		if (!$user->google2fa_secret) {
        		$user->google2fa_secret = $google2fa->generateSecretKey();
        		$user->save();
    		}

		if (empty($user->google2fa_secret)) {
        		$user->google2fa_secret = $google2fa->generateSecretKey();
        		$user->save();
    		}

		$qrCodeUrl = $google2fa->getQRCodeInline(
        		config('app.name'),
        		$user->email,
        		$user->google2fa_secret
    		);

		return view('auth.2fa_setup', [
        		'qrCodeUrl' => $qrCodeUrl,
			'secret' => $user->google2fa_secret
    		]);
	}

	public function cancel2fa(Request $request)
	{
    		$user = Auth::user();

    		if ($user) {
        		// Kosongkan kolom secret
        		$user->google2fa_secret = null;
        		$user->save();
    		}

    		// Lakukan logout
    		Auth::logout();
    		$request->session()->invalidate();
    		$request->session()->regenerateToken();

    		return redirect('/')->with('info', 'Setup 2FA cancel.');
	}

	public function finishSetup(Request $request)
    	{
        	$request->validate([
            	'one_time_password' => 'required|numeric',
        	]);

        	$google2fa = app('pragmarx.google2fa');
        	$user = auth()->user();

        	$valid = $google2fa->verifyKey($user->google2fa_secret, $request->one_time_password);

        	if ($valid) {
            		app(Authenticator::class)->boot($request)->login();
			$user->google2fa_secret = $secret;
			$user->has_2fa => 1;
        		$user->save();

            		return redirect()->route('dashboard')->with('success', '2FA Berhasil diaktifkan!');
        	}

        	return back()->withErrors(['one_time_password' => 'Kode OTP salah, silakan coba lagi.']);
    	}

    public function showVerifyForm()
    {
        return view('auth.2fa_verify');
    }

	public function verifyOtp(Request $request)
    {
        $request->validate([
            'one_time_password' => 'required|numeric',
        ]);

        $authenticator = app('pragmarx.google2fa');

        // Lakukan verifikasi kode
        if ($authenticator->verifyKey(auth()->user()->google2fa_secret, $request->one_time_password)) {
            
            // Tandai session bahwa user sudah melewati 2FA
            $authenticator->login();

		if (auth()->user()->role === 'admin') { 
            		return redirect()->intended('dashboard');
        	}

            return redirect()->intended(route('products.etalase'));
        }

        return back()->withErrors(['one_time_password' => 'Kode OTP tidak valid atau sudah kadaluwarsa.']);
    }
}
